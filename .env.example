# Database Configuration
DB_HOST=127.0.0.1
DB_NAME=beepbeep_db
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# Public site URL used in verification/password reset links
SITE_URL=http://localhost:8000

# Email sender identity
MAIL_FROM_NAME=Beep Beep Driving School
MAIL_FROM_EMAIL=info@example.com
MAIL_REPLY_TO=support@example.com

# Email transport: mail or smtp
MAIL_TRANSPORT=mail

# SMTP settings (used when MAIL_TRANSPORT=smtp)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_ENCRYPTION=tls
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SMTP_AUTH=true

# Gmail SMTP example (replace values in your real .env)
# 1) Enable 2-Step Verification on the Gmail account.
# 2) Create an App Password and use it as SMTP_PASSWORD.
# 3) Do not use your normal Gmail password.
#
# MAIL_TRANSPORT=smtp
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_ENCRYPTION=tls
# SMTP_AUTH=true
# SMTP_USERNAME=yourname@gmail.com
# SMTP_PASSWORD=your_16_char_app_password
# MAIL_FROM_EMAIL=yourname@gmail.com
# MAIL_REPLY_TO=yourname@gmail.com
